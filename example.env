# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#   Limbo 1.9.314.229
#
#   REQUIRED SETTINGS:
#
#   1. Limbo username and password
#   2. MusicBrainz Replication Token
#   3. Limbo/SLSKD Parent Mount  (for download features)
#
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

# REQUIRED SETTING - used for accessing Limbo and SLSKD WebUIs

LIMBO_USERNAME=
LIMBO_PASSWORD=


# REQUIRED SETTING - go to https://metabrainz.org/profile

MUSICBRAINZ_REPLICATION_TOKEN=


# REQUIRED SETTING:
# • slskd and download features will be unavailable without this set
# • This path will be available in slskd as "/music"
# • Other paths will be created under this path if not set below
# • Paths can be configured under any of these mounts in the webUI

LIMBO_SLSKD_PARENT_MOUNT=


# Default Paths
# • Can be chaged in webUI and different top-levels can be set below
#
# Download folder (where downloaded files finish)
#  LIMBO_SLSKD_PARENT_MOUNT/slskd_downloads
#
# Incomplete Folder (where downloaded files start)
#  LIMBO_SLSKD_PARENT_MOUNT/slskd_downloads/slskd_incomplete
#
# Shared Folder (music files to be shared publicly on Soulseek)
#  LIMBO_SLSKD_PARENT_MOUNT/shared_files


# Optional - set this if you want a download path
#  outside the above parent mount
# • Folder can be changed in webUI

LIMBO_SLSKD_DOWNLOADS_MOUNT=


# Optional - Default "incomplete" under the download folder"
# • Folder can be changed in webUI

LIMBO_SLSKD_INCOMPLETE_DOWNLOADS_MOUNT=


# Optional - set this if you want a share path
#  outside the above parent mount
# • Folder can be changed in webUI

LIMBO_SLSKD_SHARING_MOUNT=

# Optional: set to 0 to keep slskd (and slskd-preflight) down while the rest
# of the stack can still run with `docker compose up -d`.
# Set back to 1 to re-enable slskd.
LIMBO_SLSKD_SCALE=1


# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

LIMBO_PORT=5001
SLSKD_WEB_SERVER_PORT=5030
SLSKD_HTTPS_SERVER_PORT=5031
MUSICBRAINZ_WEB_SERVER_PORT=5000
MUSICBRAINZ_WEB_SERVER_HOST=localhost

# Edit the timezone to see times relative to your location
TZ=America/Toronto

# ===============================================================================
#
# Limbo Hook Settings (Advanced use for adding third-party modules)
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

# Optional extension hooks (run after built-in processing)
# LIMBO_DB_HOOK_AFTER_MODULE=
# LIMBO_DB_HOOK_AFTER_PATH=
# LIMBO_MITM_AFTER_MODULE=
# LIMBO_MITM_AFTER_PATH=

# ===============================================================================
#
# Stack Network Settings
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

# - - - - - - - - - - - - - - - - - - - -
# Network type: bridge | macvlan | ipvlan
MUSICBRAINZ_NETWORK_TYPE=bridge
LIDARR_METADATA_CONFIG=bridge
# Required for macvlan/ipvlan
MUSICBRAINZ_NETWORK_PARENT=
MUSICBRAINZ_NETWORK_SUBNET=
MUSICBRAINZ_NETWORK_GATEWAY=
# Optional for macvlan/ipvlan
MUSICBRAINZ_NETWORK_IP_RANGE=
# Optional: static IP for musicbrainz on macvlan/ipvlan (others stay on bridge)
MUSICBRAINZ_NETWORK_IP=
# Optional: static LAN IP for limbo when macvlan/ipvlan is enabled
LIMBO_NETWORK_IP=
# Optional for ipvlan: l2 or l3
MUSICBRAINZ_IPVLAN_MODE=
# - - - - - - - - - - - - - - - - - - - -


# ===============================================================================
#
# ADVANCED : Database Settings
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

POSTGRES_SHARED_BUFFERS=4GB
POSTGRES_SHM_SIZE=4GB
SOLR_HEAP=4g

MB_DB_HOST=db
MB_DB_PORT=5432
MB_DB_USER=musicbrainz
MB_DB_PASSWORD=musicbrainz
MB_DB_NAME=musicbrainz_db
MUSICBRAINZ_SERVER_PROCESSES=10

REDIS_HOST=redis
REDIS_PORT=6379

LIMBO_CACHE_DB=lm_cache_db
LIMBO_CACHE_USER=limbo
LIMBO_CACHE_PASSWORD=limbo
LIMBO_CACHE_HOST=db
LIMBO_CACHE_PORT=5432
SLSKD_SLSK_PORT=50300

# - - - - - - - - - - - - - - - - - - - -

COMPOSE_PROJECT_NAME=limbo
LIMBO_CHANNEL=latest

## Limbo Image (optional override; leave unset to use LIMBO_CHANNEL)
# LIMBO_IMAGE=espressomatic/limbo-bridge:latest

# .
LIMBO_DOCKERHUB_NAMESPACE=espressomatic
LIMBO_DOCKERHUB_REPO_PREFIX=limbo
MBMS_DOCKERHUB_NAMESPACE=espressomatic
MBMS_DOCKERHUB_REPO_PREFIX=limbo
