# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#   $VERSION
#
#   REQUIRED SETTINGS:
#
#   1. MUSICBRAINZ_REPLICATION_TOKEN
#   2. LIMBO_DLDR_PARENT_FOLDER
#
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

# REQUIRED SETTING to build database - go to https://metabrainz.org/profile
MUSICBRAINZ_REPLICATION_TOKEN=


# TIMEZONE OVERRIDE: if your host environment's timezone is incorrect
# TZ=America/Toronto

# Migrate all DL vars into the UI - and directory support for Lidarr host paths and external SLSKD use SMB browsing

LIMBO_DLDR_PARENT_FOLDER=
LIMBO_DLDR_DOWNLOADS=
LIMBO_DLDR_INCOMPLETE_DOWNLOADS=
LIMBO_DLDR_SHARING_PATH=


# ===============================================================================
#
# PORT Assignments
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

LIMBO_PORT=4808
LIMBO_HOST_HELPER_PORT=4809
LIMBO_STICK_PORT=4810
LIMBO_DLDR_API_PORT=4812
LIMBO_DLDR_INBOUND_PORT=50300
LIMBO_CACHE_PORT=4818
MB_DB_PORT=4818
REDIS_PORT=4819
MUSICBRAINZ_WEB_SERVER_PORT=4820

SOULSEEK_INBOUND_PORT=50300

# OPTIONAL - host IP detection override for Limbo auto-host URL mode
LIMBO_HOST_IP=


# ===============================================================================
#
# ADVANCED : Database Settings
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

POSTGRES_SHARED_BUFFERS=4GB
POSTGRES_SHM_SIZE=4GB
SOLR_HEAP=4g


# ===============================================================================
#
#   Limbo 1.9.329.855
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

# Optional extension hooks (run after built-in processing)
# LIMBO_DB_HOOK_AFTER_MODULE=
# LIMBO_DB_HOOK_AFTER_PATH=
# LIMBO_MITM_AFTER_MODULE=
# LIMBO_MITM_AFTER_PATH=

# - - - - - - - - - - - - - - - - - - - -

LIMBO_CHANNEL=latest

# LIMBO_CHANNEL=test
# LIMBO_CHANNEL=latest

# .
LIMBO_DOCKERHUB_NAMESPACE=espressomatic
LIMBO_DOCKERHUB_REPO_PREFIX=limbo
