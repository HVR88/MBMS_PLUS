# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#   $VERSION
#
#   REQUIRED SETTINGS:
#
#   1. MusicBrainz Replication Token
#   2. Limbo/SLSKD Parent Mount  (for download features)
#
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

# REQUIRED SETTING to build database - go to https://metabrainz.org/profile

MUSICBRAINZ_REPLICATION_TOKEN=


# TIMEZONE OVERRIDE: if your host environment's timezone is incorrect

# TZ=America/Toronto


# REQUIRED SETTING for Downloader:
#
# • Download features will be unavailable without setting this path
# • The path will be available in SLSKD as "/music"
# • Other paths are created under this path if not also set below
# • Paths can be re-configured under any of these mounts in the SLSKD webUI

LIMBO_SLSKD_PARENT_MOUNT=

# DEFAULT PATHS:
#
# Download folder - where downloaded files finish
#  LIMBO_SLSKD_PARENT_MOUNT/slskd_downloads
#
# Incomplete Folder - where downloaded files start
#  LIMBO_SLSKD_PARENT_MOUNT/slskd_downloads/slskd_incomplete
#
# Shared Folder - music files to be shared publicly on Soulseek network
#  LIMBO_SLSKD_PARENT_MOUNT/shared_files


# OPTIONAL - set a download path outside the above parent mount
# • Folder can be changed in webUI

LIMBO_SLSKD_DOWNLOADS_MOUNT=

# OPTIONAL - set a incomplete path outside the above parent mount
# • Folder can be changed in webUI
# • Default is under the download folder

LIMBO_SLSKD_INCOMPLETE_DOWNLOADS_MOUNT=

# OPTIONAL - set a share path outside the above parent mount
# • Folder can be changed in webUI

LIMBO_SLSKD_SHARING_MOUNT=


# OPTIONAL - Lidarr root folders for Limbo Track Scanner path translation
# • Set each to a host path used by Lidarr root folders
# • Limbo mounts these at /limbo/lidarr-root-1 .. /limbo/lidarr-root-5
# • Use as many slots as needed
LIMBO_LIDARR_ROOT_FOLDER_1=
LIMBO_LIDARR_ROOT_FOLDER_2=
LIMBO_LIDARR_ROOT_FOLDER_3=
LIMBO_LIDARR_ROOT_FOLDER_4=
LIMBO_LIDARR_ROOT_FOLDER_5=


# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -


LIMBO_PORT=4808
LIMBO_HOST_HELPER_PORT=4809
MUSICBRAINZ_WEB_SERVER_PORT=4815
SLSKD_WEB_SERVER_PORT=5030
SLSKD_HTTPS_SERVER_PORT=5031

# OPTIONAL - host IP detection override for Limbo auto-host URL mode
# If unset, deploy preflight derives host LAN IPv4 automatically.
LIMBO_HOST_IP=


# ===============================================================================
#
#   Limbo 1.9.327.829
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

# Optional extension hooks (run after built-in processing)
# LIMBO_DB_HOOK_AFTER_MODULE=
# LIMBO_DB_HOOK_AFTER_PATH=
# LIMBO_MITM_AFTER_MODULE=
# LIMBO_MITM_AFTER_PATH=

# ===============================================================================
#
# Lidarr Library Tool (DB + Async Backfill)
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

# Enable periodic ingestion from Lidarr into lidarr-library-tool DB
LIMBO_LIDARR_LIBRARY_TOOL_ENABLED=false

# SQLite DB file used by lidarr-library-tool
LIMBO_LIDARR_LIBRARY_TOOL_DB_PATH=/metadata/limbo_data/lidarr-library-tool.db

# Scheduler timing
LIMBO_LIDARR_LIBRARY_TOOL_SYNC_INTERVAL_SECONDS=1800
LIMBO_LIDARR_LIBRARY_TOOL_STARTUP_DELAY_SECONDS=45
LIMBO_LIDARR_LIBRARY_TOOL_HTTP_TIMEOUT_SECONDS=120

# Backfill debounce (seconds) for derived-field updates
LIMBO_LIDARR_LIBRARY_TOOL_BACKFILL_DEBOUNCE_SECONDS=0.25


# ===============================================================================
#
# ADVANCED : Database Settings
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

POSTGRES_SHARED_BUFFERS=4GB
POSTGRES_SHM_SIZE=4GB
SOLR_HEAP=4g

MUSICBRAINZ_SERVER_PROCESSES=10
USE_CACHE=true

# Limbo bridge runtime pressure controls
LIMBO_SEARCH_CONCURRENCY=4
LIMBO_MBDB_POOL_MIN=1
LIMBO_MBDB_POOL_MAX=8
LIMBO_CACHE_POOL_MIN=1
LIMBO_CACHE_POOL_MAX=4
LIMBO_PROVIDER_ID_POOL_MIN=1
LIMBO_PROVIDER_ID_POOL_MAX=4
LIMBO_DB_HOOK_POOL_MIN=1
LIMBO_DB_HOOK_POOL_MAX=4

REDIS_PORT=6379
MB_DB_PORT=5432
LIMBO_CACHE_PORT=5432
SLSKD_SLSK_PORT=50300

MB_DB_USER=musicbrainz
MB_DB_PASSWORD=musicbrainz

LIMBO_CACHE_USER=limbo
LIMBO_CACHE_PASSWORD=limbo


# - - - - - - - - - - - - - - - - - - - -

COMPOSE_PROJECT_NAME=limbo
LIMBO_CHANNEL=latest


# Optional: set to 0 to disabkle slskd startup
# Set back to 1 to re-enable slskd
#
# Download features can be disabled in the limbo webUI's settings

LIMBO_SLSKD_SCALE=1


## Limbo Image (optional override; leave unset to use LIMBO_CHANNEL)
# LIMBO_IMAGE=espressomatic/limbo:latest
# LIMBO_IMAGE=espressomatic/limbo:test

# Optional: hard-pin MusicBrainz image so it never auto-updates on `docker compose pull`.
# Recommended for long-lived immutable deployments:
#   1) set MUSICBRAINZ_IMAGE to an immutable digest reference
#   2) set MUSICBRAINZ_PULL_POLICY=never
# Example:
# MUSICBRAINZ_IMAGE=espressomatic/limbo-musicbrainz:test@sha256:REPLACE_WITH_DIGEST
# MUSICBRAINZ_PULL_POLICY=never
#
# Default behavior if unset:
# - MusicBrainz follows LIMBO_CHANNEL tag and only pulls when image is missing locally.
# MUSICBRAINZ_IMAGE=
# MUSICBRAINZ_PULL_POLICY=missing

# .
LIMBO_DOCKERHUB_NAMESPACE=espressomatic
LIMBO_DOCKERHUB_REPO_PREFIX=limbo
