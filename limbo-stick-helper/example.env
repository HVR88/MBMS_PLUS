# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#
#   NO REQUIRED SETTINGS
#
#   This file contains only optional settings
#
#   Limbo Stick doesn't need env config by default
#
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

LIMBOSTICK_CHANNEL=latest

# ===============================================================================
#
# For UNRAID, use Compose Manager Plus plugin with settings below (uncomment):
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#
# LIMBO_DATA_ROOT=/mnt/user/appdata/limbo
#
# LIMBO_UID= 99
# LIMBO_GID= 100
# LIMBO_UMASK= 002
#
# LIMBO_NETWORK_NAME=
# LIMBO_NETWORK_EXTERNAL=


# ===============================================================================
#
# ADVANCED
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

# Optional manual DB override settings (advanced)
# Use these when auto-discovery can't resolve Lidarr DB backend details

# Backend override: auto | sqlite | postgres
LIMBO_STICK_DB_TYPE=
LIMBO_STICK_DB_SQLITE_PATH=
LIMBO_STICK_LIDARR_CONFIG_XML=

# Prefer a full URL override when available:
# LIMBO_STICK_DB_POSTGRES_URL=postgresql://user:pass@host:5432/lidarr-main
LIMBO_STICK_DB_POSTGRES_URL=

# Or use split fields to build URL automatically:
LIMBO_STICK_DB_POSTGRES_HOST=
LIMBO_STICK_DB_POSTGRES_PORT=
LIMBO_STICK_DB_POSTGRES_USER=
LIMBO_STICK_DB_POSTGRES_PASSWORD=
LIMBO_STICK_DB_POSTGRES_DB=
