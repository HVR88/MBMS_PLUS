# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#
#   NO REQUIRED SETTINGS
#
#   This file contains only optional settings
#
#   Limbo Stick doesn't need env config by default
#
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

LIMBOSTICK_CHANNEL=latest

# Optional storage and network override
#
# Default: Docker managed volumes (best for direct host installs, LXC, VM, etc.)
# Override: Automatic host bind mounts under custom path (best for Unraid (Docker Compose Plus plugin recommended))
#
# Unraid suggested values:
# LIMBOSTICK_DATA_ROOT=/mnt/user/appdata/limbo_stick
# LIMBOSTICK_NETWORK_NAME=your_custom_bridge_name
# LIMBOSTICK_NETWORK_EXTERNAL=true
# LIMBOSTICK_UID=99
# LIMBOSTICK_GID=100
# LIMBOSTICK_UMASK=002
#
LIMBOSTICK_DATA_ROOT=
LIMBOSTICK_NETWORK_NAME=
LIMBOSTICK_NETWORK_EXTERNAL=

# Optional runtime UID/GID remap (only when using LIMBOSTICK_DATA_ROOT for host bind mode)
LIMBOSTICK_UID=
LIMBOSTICK_GID=
LIMBOSTICK_UMASK=
