# REQUIRED: Lidarr URL:PORT and API KEY
LIDARR_URL=
API_KEY=


# ------------------------------------------------------------------------------------

# Limbo Stick listener
LIMBO_STICK_PORT=4810

# Lidarr container name for stop/start behavior in sqlite DB mode
LIDARR_CONTAINER_NAME=lidarr

# Mount path on host that contains Lidarr's config.xml + lidarr.db
# This is used by docker-compose as: ${LIDARR_CONFIG_PATH}:/config
LIDARR_CONFIG_PATH=./lidarr-config

# In-container paths
LIDARR_CONFIG_XML=/config/config.xml
LIDARR_SQLITE_PATH=/config/lidarr.db

# Optional explicit Postgres URL. Leave blank to auto-discover from env/config.xml
LIDARR_POSTGRES_URL=

# Optional explicit Postgres fields used by auto-discovery in this container
LIDARR__POSTGRES__HOST=
LIDARR__POSTGRES__PORT=
LIDARR__POSTGRES__USER=
LIDARR__POSTGRES__PASSWORD=
LIDARR__POSTGRES__MAINDB=
LIDARR__POSTGRES__LOGDB=
